<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 버튼 등 작은 컴포넌트(Small)에 적용되는 둥근 모서리 -->
    <style name="ShapeAppearance.WebScraper.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- 다이얼로그, 카드 등 중간 크기 컴포넌트(Medium)에 적용되는 둥근 모서리 -->
    <style name="ShapeAppearance.WebScraper.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- 바텀시트 등 큰 컴포넌트(Large)에 적용되는 둥근 모서리 -->
    <style name="ShapeAppearance.WebScraper.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Theme.WebScraper" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/colorPrimaryDark</item>

        <!-- 앱 전반의 Material 버튼/다이얼로그/카드가 각지지 않고 둥글게 보이도록 전역 적용 -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.WebScraper.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.WebScraper.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.WebScraper.LargeComponent</item>
    </style>
</resources>
